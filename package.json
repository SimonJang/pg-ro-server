{
  "name": "pg-readonly-mcp",
  "version": "1.0.0",
  "description": "MCP server for interacting with PostgreSQL",
  "homepage": "https://github.com/SimonJang/pg-readonly-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimonJang/pg-readonly-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SimonJang/pg-readonly-mcp/issues"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pg-readonly-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:integration": "bash scripts/integration-test.sh",
    "prepublishOnly": "npm test && npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release": "npm publish --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
